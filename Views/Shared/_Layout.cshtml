<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Estoque</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
        }

        .navbar {
            background-color: #1a1a2e !important;
            box-shadow: 0 2px 8px rgba(0,0,0,0.3);
        }

        .navbar-brand {
            color: #e94560 !important;
            font-weight: 700;
            font-size: 1.3rem;
            letter-spacing: 1px;
        }

        .nav-link {
            color: #ccc !important;
            font-weight: 500;
            transition: color 0.2s;
        }

            .nav-link:hover {
                color: #e94560 !important;
            }

            .nav-link.active {
                color: #e94560 !important;
            }

        .container-main {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 2px solid #e94560;
        }

        .page-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: #1a1a2e;
            margin: 0;
        }

        .page-subtitle {
            color: #888;
            margin: 0;
            font-size: 0.9rem;
        }

        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            overflow: hidden;
        }

        .card-header {
            background-color: #fff;
            border-bottom: 1px solid #eee;
            padding: 14px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.95rem;
            color: #555;
        }

        .table {
            margin: 0;
            background: #fff;
        }

            .table thead th {
                background-color: #1a1a2e;
                color: #fff;
                font-weight: 600;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                border: none;
                padding: 14px 16px;
            }

            .table tbody tr {
                border-bottom: 1px solid #f0f0f0;
                transition: background 0.15s;
            }

                .table tbody tr:hover {
                    background-color: #f8f9ff;
                }

            .table tbody td {
                padding: 12px 16px;
                vertical-align: middle;
                color: #333;
            }

        .btn-primary {
            background-color: #e94560;
            border-color: #e94560;
            border-radius: 8px;
            font-weight: 600;
            padding: 8px 18px;
        }

            .btn-primary:hover {
                background-color: #c73652;
                border-color: #c73652;
            }

        .btn-outline {
            background: transparent;
            border: 1px solid #e94560;
            color: #e94560;
            border-radius: 8px;
            padding: 6px 14px;
            font-size: 0.85rem;
            text-decoration: none;
            transition: all 0.2s;
        }

            .btn-outline:hover {
                background-color: #e94560;
                color: #fff;
            }

        .btn-sm {
            border-radius: 6px;
            padding: 4px 10px;
            font-size: 0.8rem;
        }

        .badge-id {
            background-color: #1a1a2e;
            color: #fff;
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 0.8rem;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #aaa;
        }

            .empty-state .empty-icon {
                font-size: 3rem;
                margin-bottom: 12px;
            }

        .action-group {
            display: flex;
            gap: 6px;
        }

        footer {
            background-color: #1a1a2e;
            color: #aaa;
            text-align: center;
            padding: 16px;
            margin-top: 40px;
            font-size: 0.85rem;
        }

            footer a {
                color: #e94560;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    📦 Sistema de Estoque
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">🏠 Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Produto" asp-action="Index">🛒 Produtos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Clientes" asp-action="Index">👤 Clientes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Pedido" asp-action="Index">📋 Pedidos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Expedicao" asp-action="Index">🚚 Expedição</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-main">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div>
            &copy; 2026 - Sistema de Estoque &nbsp;|&nbsp;
            Projeto Acadêmico — ASP.NET Core 8 + Entity Framework
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>