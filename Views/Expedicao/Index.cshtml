@model IEnumerable<Projeto_Estoque.Models.Expedicao>
@using Projeto_Estoque.Models

@{
    ViewData["Title"] = "Expedições";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">📦 Expedições</h2>
    <div>
        <a asp-action="Relatorios" class="btn btn-outline-secondary me-2">
            📊 Relatórios
        </a>
        <a asp-action="Create" class="btn btn-primary">
            ＋ Nova Expedição
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Nenhuma expedição cadastrada ainda.</div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>#ID</th>
                <th>Pedido</th>
                <th>Cliente</th>
                <th>Transportadora</th>
                <th>Data de Envio</th>
                <th>Status</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>Pedido #@item.PedidoId</td>
                    <td>@item.Pedido?.Cliente?.Nome</td>
                    <td>@item.Transportadora</td>
                    <td>@item.DataEnvio.ToString("dd/MM/yyyy")</td>
                    <td>
                        <span class="badge @GetBadgeClass(item.Status)">
                            @item.Status
                        </span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-info" title="Detalhes">🔍</a>
                        @if (item.Status != StatusExpedicao.Entregue)
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-warning" title="Editar">✏️</a>
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger" title="Excluir">🗑️</a>
                        }
                        else
                        {
                            <span class="badge bg-success" title="Entregue — somente leitura">✅ Entregue</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@functions {
    string GetBadgeClass(StatusExpedicao status) => status switch
    {
        StatusExpedicao.Pendente => "bg-secondary",
        StatusExpedicao.EmSeparacao => "bg-warning text-dark",
        StatusExpedicao.ProntoParaEnvio => "bg-info text-dark",
        StatusExpedicao.Despachado => "bg-primary",
        StatusExpedicao.EmTransporte => "bg-primary",
        StatusExpedicao.Entregue => "bg-success",
        StatusExpedicao.Cancelado => "bg-danger",
        _ => "bg-secondary"
    };
}