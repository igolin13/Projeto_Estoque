@model Projeto_Estoque.Models.Expedicao
@using Projeto_Estoque.Models

@{
    ViewData["Title"] = $"Expedição #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🔍 Detalhes — Expedição #@Model.Id</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning me-2">
            ✏️ Editar
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
    </div>
</div>

<div class="row g-4">

    {{!-- Dados da Expedição --}}
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-primary text-white fw-bold">
                📦 Dados da Expedição
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">ID</dt>
                    <dd class="col-sm-7">@Model.Id</dd>

                    <dt class="col-sm-5">Transportadora</dt>
                    <dd class="col-sm-7">@Model.Transportadora</dd>

                    <dt class="col-sm-5">Data de Envio</dt>
                    <dd class="col-sm-7">@Model.DataEnvio.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-5">Status</dt>
                    <dd class="col-sm-7">
                        <span class="badge @GetBadgeClass(Model.Status)">
                            @Model.Status
                        </span>
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    {{!-- Dados do Cliente / Pedido --}}
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-secondary text-white fw-bold">
                👤 Cliente / Pedido
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Pedido</dt>
                    <dd class="col-sm-7">#@Model.PedidoId</dd>

                    <dt class="col-sm-5">Data do Pedido</dt>
                    <dd class="col-sm-7">@Model.Pedido?.DataPedido.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-5">Cliente</dt>
                    <dd class="col-sm-7">@Model.Pedido?.Cliente?.Nome</dd>

                    <dt class="col-sm-5">E-mail</dt>
                    <dd class="col-sm-7">@Model.Pedido?.Cliente?.Email</dd>

                    <dt class="col-sm-5">Valor Total</dt>
                    <dd class="col-sm-7">
                        <strong>@Model.Pedido?.ValorTotal.ToString("C")</strong>
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    {{!-- Produtos do Pedido --}}
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-dark text-white fw-bold">
                🛒 Produtos do Pedido
            </div>
            <div class="card-body p-0">
                @if (Model.Pedido?.PedidoProdutos == null || !Model.Pedido.PedidoProdutos.Any())
                {
                    <p class="p-3 mb-0 text-muted">Nenhum produto encontrado neste pedido.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Produto</th>
                                <th class="text-center">Quantidade</th>
                                <th class="text-end">Preço Unit.</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pp in Model.Pedido.PedidoProdutos)
                            {
                                <tr>
                                    <td>@pp.Produto?.Nome</td>
                                    <td class="text-center">@pp.Quantidade</td>
                                    <td class="text-end">@pp.Produto?.Preco.ToString("C")</td>
                                    <td class="text-end">
                                        @((pp.Produto?.Preco ?? 0) * pp.Quantidade).ToString("C")
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold">Total de itens:</td>
                                <td class="text-end fw-bold">
                                    @Model.Pedido.PedidoProdutos.Sum(pp => pp.Quantidade)
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                }
            </div>
        </div>
    </div>

</div>

@functions {
    string GetBadgeClass(StatusExpedicao status) => status switch
    {
        StatusExpedicao.Pendente        => "bg-secondary",
        StatusExpedicao.EmSeparacao     => "bg-warning text-dark",
        StatusExpedicao.ProntoParaEnvio => "bg-info text-dark",
        StatusExpedicao.Despachado      => "bg-primary",
        StatusExpedicao.EmTransporte    => "bg-primary",
        StatusExpedicao.Entregue        => "bg-success",
        StatusExpedicao.Cancelado       => "bg-danger",
        _                               => "bg-secondary"
    };
}
