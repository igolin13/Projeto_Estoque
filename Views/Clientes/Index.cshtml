@model IEnumerable<Projeto_Estoque.Models.Cliente>

@{
    ViewData["Title"] = "Clientes";
}

<div class="page-header">
    <div>
        <h1 class="page-title">👤 Clientes</h1>
        <p class="page-subtitle">Gerencie a base de clientes</p>
    </div>
    <div style="display:flex; gap:10px;">
        <a asp-action="Indicadores" class="btn btn-outline">📊 Indicadores</a>
        <a asp-action="Create" class="btn btn-primary">+ Novo Cliente</a>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <span>Total: <strong>@Model.Count() clientes</strong></span>
    </div>
    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">👤</div>
            <h3>Nenhum cliente cadastrado</h3>
            <p>Clique em "Novo Cliente" para começar.</p>
        </div>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nome</th>
                    <th>E-mail</th>
                    <th>Telefone</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="badge-id">@item.Id</span></td>
                        <td><strong>@item.Nome</strong></td>
                        <td>@item.Email</td>
                        <td>@item.Telefone</td>
                        <td>
                            <div class="action-group">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Detalhes</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Editar</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>