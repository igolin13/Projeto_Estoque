@{
    ViewData["Title"] = "Indicadores de Clientes";
}

<h1 class="mb-4">Painel de Indicadores LINQ</h1>

<div class="row">
    <div class="col-md-12 mb-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Consulta 1 - Clientes e seus Pedidos</h5>
            </div>
            <div class="card-body">
                <table class="table table-sm table-bordered">
                    <thead>
                        <tr><th>Cliente</th><th>Nº Pedido</th><th>Valor</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ViewBag.Consulta1)
                        {
                            <tr>
                                <td>@item.NomeCliente</td>
                                <td>@item.IdPedido</td>
                                <td>@item.ValorPedido.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Consulta 2 - Total de Pedidos por Cliente</h5>
            </div>
            <div class="card-body">
                <table class="table table-sm table-bordered">
                    <thead>
                        <tr><th>Cliente</th><th>Qtd Pedidos</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ViewBag.Consulta2)
                        {
                            <tr>
                                <td>@item.NomeCliente</td>
                                <td>@item.QuantidadePedidos</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">Consulta 3 - Clientes VIP (> 3 Pedidos)</h5>
            </div>
            <div class="card-body">
                <table class="table table-sm table-bordered">
                    <thead>
                        <tr><th>Cliente</th><th>Total Pedidos</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ViewBag.Consulta3)
                        {
                            <tr>
                                <td>@item.NomeCliente</td>
                                <td>@item.TotalPedidos</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Voltar para a Lista de Clientes</a>
</div>