@model Projeto_Estoque.Models.ViewModels.PedidoViewModel

@{
    ViewData["Title"] = "Novo Pedido";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Novo Pedido</h1>
        <p class="page-subtitle">Selecione o cliente e adicione os produtos</p>
    </div>
    <a asp-action="Index" class="btn btn-outline">← Voltar</a>
</div>

<form method="post" asp-action="Create" id="formPedido">
    @Html.AntiForgeryToken()

    <div class="form-grid">

        <!-- Seleção de Cliente -->
        <div class="card">
            <div class="card-section-title">👤 Cliente</div>
            <div class="form-group">
                <label class="form-label" for="clienteId">Selecione o cliente *</label>
                <select name="clienteId" id="clienteId" class="form-control" required>
                    <option value="">— Selecione —</option>
                    @foreach (var c in Model.Clientes)
                    {
                        <option value="@c.Value">@c.Text</option>
                    }
                </select>
            </div>
        </div>

        <!-- Adicionar Produtos -->
        <div class="card">
            <div class="card-section-title">📦 Adicionar Produto</div>
            <div class="add-produto-form">
                <div class="form-group">
                    <label class="form-label">Produto</label>
                    <select id="selectProduto" class="form-control">
                        <option value="">— Selecione —</option>
                        @foreach (var p in Model.Produtos)
                        {
                            <option value="@p.Value" data-preco="@p.Value">@p.Text</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Quantidade</label>
                    <input type="number" id="inputQtd" class="form-control" value="1" min="1" />
                </div>
                <button type="button" class="btn btn-primary" onclick="adicionarProduto()">Adicionar</button>
            </div>
        </div>

    </div>

    <!-- Tabela de itens adicionados -->
    <div class="card mt-4">
        <div class="card-header">
            <span class="card-section-title">Itens do Pedido</span>
            <span id="totalDisplay" class="valor-total">R$ 0,00</span>
        </div>

        <div id="emptyMessage" class="empty-state">
            <div class="empty-icon">🛒</div>
            <p>Nenhum produto adicionado ainda.</p>
        </div>

        <table class="table" id="tabelaItens" style="display:none;">
            <thead>
                <tr>
                    <th>Produto</th>
                    <th>Preço Unit.</th>
                    <th>Quantidade</th>
                    <th>Subtotal</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="corpoTabela"></tbody>
            <tfoot>
                <tr class="total-row">
                    <td colspan="3"><strong>Total</strong></td>
                    <td id="totalTabela" class="valor-total"><strong>R$ 0,00</strong></td>
                    <td></td>
                </tr>
            </tfoot>
        </table>

        <!-- Campos hidden que serão enviados no form -->
        <div id="camposHidden"></div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary btn-lg" id="btnSalvar" disabled>
            Confirmar Pedido
        </button>
        <a asp-action="Index" class="btn btn-outline">Cancelar</a>
    </div>
</form>

@section Scripts {
<script>
    // Dados dos produtos vindos do servidor
    const produtosData = {};

    // Pré-carrega os preços dos produtos
    document.querySelectorAll('#selectProduto option[value]').forEach(opt => {
        if (opt.value) {
            // O texto tem formato "Nome - R$ X.XX", extrai o preço
            const match = opt.textContent.match(/R\$\s*([\d.,]+)/);
            if (match) {
                const precoStr = match[1].replace('.', '').replace(',', '.');
                produtosData[opt.value] = {
                    id: opt.value,
                    nome: opt.textContent.split(' - ')[0].trim(),
                    preco: parseFloat(precoStr)
                };
            }
        }
    });

    let itens = []; // Lista de itens adicionados

    function adicionarProduto() {
        const select = document.getElementById('selectProduto');
        const qtdInput = document.getElementById('inputQtd');
        const produtoId = select.value;
        const qtd = parseInt(qtdInput.value);

        if (!produtoId) { alert('Selecione um produto.'); return; }
        if (!qtd || qtd < 1) { alert('Quantidade deve ser maior que zero.'); return; }

        // Verifica se já foi adicionado
        const existente = itens.find(i => i.id === produtoId);
        if (existente) {
            existente.quantidade += qtd;
        } else {
            const prod = produtosData[produtoId];
            itens.push({ id: produtoId, nome: prod.nome, preco: prod.preco, quantidade: qtd });
        }

        atualizarTabela();
        select.value = '';
        qtdInput.value = 1;
    }

    function removerItem(id) {
        itens = itens.filter(i => i.id !== id);
        atualizarTabela();
    }

    function atualizarTabela() {
        const tbody = document.getElementById('corpoTabela');
        const tabela = document.getElementById('tabelaItens');
        const empty = document.getElementById('emptyMessage');
        const hidden = document.getElementById('camposHidden');
        const btnSalvar = document.getElementById('btnSalvar');

        tbody.innerHTML = '';
        hidden.innerHTML = '';

        let total = 0;

        itens.forEach((item, idx) => {
            const sub = item.preco * item.quantidade;
            total += sub;

            tbody.innerHTML += `
                <tr>
                    <td><strong>${item.nome}</strong></td>
                    <td>R$ ${item.preco.toFixed(2).replace('.', ',')}</td>
                    <td><span class="tag">${item.quantidade}</span></td>
                    <td><strong class="valor">R$ ${sub.toFixed(2).replace('.', ',')}</strong></td>
                    <td><button type="button" class="btn btn-sm btn-danger" onclick="removerItem('${item.id}')">✕</button></td>
                </tr>`;

            // Campos hidden para envio do form
            hidden.innerHTML += `<input type="hidden" name="produtoIds" value="${item.id}" />`;
            hidden.innerHTML += `<input type="hidden" name="quantidades" value="${item.quantidade}" />`;
        });

        const totalFmt = 'R$ ' + total.toFixed(2).replace('.', ',');
        document.getElementById('totalTabela').innerHTML = `<strong>${totalFmt}</strong>`;
        document.getElementById('totalDisplay').textContent = totalFmt;

        tabela.style.display = itens.length > 0 ? 'table' : 'none';
        empty.style.display = itens.length > 0 ? 'none' : 'block';
        btnSalvar.disabled = itens.length === 0;
    }
</script>
}
